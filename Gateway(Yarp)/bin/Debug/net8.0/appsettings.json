{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "usersRoute": {
        "ClusterId": "usersCluster",
        "Match": {
          "Path": "/gateway/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway/auth" },
          { "PathPrefix": "/api/auth" }
        ]
      },
      "productsRoute": {
        "ClusterId": "productsCluster",
        "Match": {
          "Path": "/gateway/products/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway/products" },
          { "PathPrefix": "/api/products" }
        ]
      },
      "orderRoute": {
        "ClusterId": "orderCluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      },
      "inventoryRoute": {
        "ClusterId": "inventoryCluster",
        "Match": {
          "Path": "/api/inventory/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "usersCluster": {
        "Destinations": {
          "d1": {
            "Address": "https://localhost:7239/"
          }
        }
      },
      "productsCluster": {
        "Destinations": {
          "d1": {
            "Address": "https://localhost:7113/"
          }
        }
      },
      "orderCluster": {
        "Destinations": {
          "d1": {
            "Address": "https://localhost:7079/"
          }
        }
      },
      "inventoryCluster": {
      "Destinations": {
        "d1": {
          "Address": "https://localhost:7048/"
        }
      }
    }
    }
  },
  "JwtSettings": {
    "Key": "Hadi1234_Secret_Key_Micro_Services_Practice"
  }
}

